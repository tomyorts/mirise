NEXT_PUBLIC_APP_NAME="MIRISE Intercom"
NEXT_PUBLIC_LIVEKIT_URL="ws://localhost:7880"
LIVEKIT_API_KEY="devkey"
LIVEKIT_API_SECRET="devsecret"

# ログイン(医院共通パスワード方式)
CLINIC_PASSWORD="change-me-staff-password"
ADMIN_PASSWORD="change-me-admin-password"
# ログインCookieの署名鍵。長いランダム文字列にする(例: openssl rand -base64 32)
AUTH_SECRET="generate-a-long-random-secret"

# 任意: ネイティブアプリ用のAPIキー。設定すると x-intercom-key ヘッダーでも
# /api/token を許可する(ログインセッションが無い端末向け)。
# INTERCOM_API_KEY="optional-native-app-api-key"
